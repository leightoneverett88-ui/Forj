# Forj backend — copy to `.env` and fill in.
# Create a Strava API application at https://www.strava.com/settings/api
# (Authorization Callback Domain must match STRAVA_REDIRECT_URI's host, e.g. "localhost")

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/auth/callback

# Athlete weight in kg — used only to estimate calories (Strava's summary omits them).
ATHLETE_WEIGHT_KG=92

PORT=3000

# Set FORJ_MODE=local to run without OAuth against data/activities.json (demo mode).
# Leave unset (and set the STRAVA_* vars above) to run on live Strava data.
# FORJ_MODE=local
